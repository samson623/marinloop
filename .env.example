# App Mode: demo | prod
VITE_APP_MODE=prod

# Supabase
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key
# Optional: OAuth callback URL (defaults to origin + /auth/callback)
VITE_OAUTH_REDIRECT_URL=http://localhost:5173/auth/callback

# OpenAI model (display only — model is enforced server-side in the edge function)
# OpenAI: set via Supabase secrets only — supabase secrets set OPENAI_API_KEY=sk-...
VITE_OPENAI_MODEL=gpt-5-nano

# Push notifications: VAPID public key from supabase/functions/_shared/vapid.ts or web push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=